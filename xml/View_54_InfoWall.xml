<?xml version="1.0" encoding="UTF-8"?>
<!-- Purpose: Info wall view implementation. -->
<!-- Usage: Provides the artwork grid plus additional metadata layout used in richer browsing screens. -->
<includes>
	<!-- Picture card used when InfoWall is rendering image library content.
	     This is a simple framed thumbnail with one centered label underneath. -->
	<include name="InfoWallPictureLayout">
		<param name="focused">false</param>
		<definition>
			<!-- Focus highlight card, only shown for the selected item. -->
			<control type="image">
				<top>0</top>
				<left>0</left>
				<width>384</width>
				<height>388</height>
				<texture colordiffuse="button_focus">colors/white.png</texture>
				<bordertexture border="21" infill="false">overlays/shadow.png</bordertexture>
				<bordersize>20</bordersize>
				<visible>$PARAM[focused]</visible>
				<include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
			</control>
			<!-- Actual picture art/thumbnail. -->
			<control type="image">
				<left>0</left>
				<top>0</top>
				<width>336</width>
				<height>300</height>
				<texture border="2" background="true">$VAR[InfoWallThumbVar]</texture>
				<aspectratio>keep</aspectratio>
			</control>
			<!-- Picture label beneath the thumbnail. -->
			<control type="label">
				<left>0</left>
				<top>318</top>
				<width>338</width>
				<textoffsetx>20</textoffsetx>
				<height>20</height>
				<align>center</align>
				<aligny>center</aligny>
				<font>font12</font>
				<label>$INFO[ListItem.Label]</label>
			</control>
		</definition>
	</include>
	<!-- Square music/add-on card used for albums, artists, and other square-art rows.
	     This layout supports either a single centered label or an album-style
	     title + artist split, plus the optional rating circle. -->
	<include name="InfoWallMusicLayout">
		<param name="fallback_image">DefaultFolder.png</param>
		<param name="main_label">$INFO[ListItem.Artist]</param>
		<param name="sub_label">$INFO[ListItem.Title]</param>
		<param name="single_label">$INFO[ListItem.Label]</param>
		<param name="focused">false</param>
		<definition>
			<!-- Focus highlight card shown when the square tile is selected. -->
			<control type="image">
				<top>-4</top>
				<left>-4</left>
				<width>324</width>
				<height>394</height>
				<texture colordiffuse="button_focus">colors/white.png</texture>
				<bordertexture border="21" infill="false">overlays/shadow.png</bordertexture>
				<bordersize>20</bordersize>
				<visible>$PARAM[focused]</visible>
				<include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
			</control>
			<!-- Main square artwork surface. -->
			<control type="image">
				<left>0</left>
				<top>0</top>
				<width>316</width>
				<height>316</height>
				<texture fallback="$PARAM[fallback_image]" background="true">$VAR[InfoWallThumbVar]</texture>
				<aspectratio>keep</aspectratio>
				<bordersize>20</bordersize>
			</control>
			<!-- Single-label mode used for non-album content. -->
			<control type="textbox">
				<left>28</left>
				<top>289</top>
				<width>262</width>
				<height>80</height>
				<font>font12</font>
				<align>center</align>
				<aligny>center</aligny>
				<label>$PARAM[single_label]</label>
				<visible>!String.IsEqual(ListItem.DBType,album)</visible>
			</control>
			<!-- Two-line album mode: track/album title on top, artist below. -->
			<control type="group">
				<visible>String.IsEqual(ListItem.DBType,album)</visible>
				<!-- Upper album/track label. -->
				<control type="label">
					<left>29</left>
					<top>300</top>
					<width>260</width>
					<label>$PARAM[sub_label]</label>
					<font>font10</font>
					<shadowcolor>text_shadow</shadowcolor>
					<scroll>$PARAM[focused]</scroll>
					<align>center</align>
				</control>
				<!-- Lower artist label. -->
				<control type="label">
					<left>29</left>
					<top>328</top>
					<width>260</width>
					<label>$PARAM[main_label]</label>
					<font>font12</font>
					<shadowcolor>text_shadow</shadowcolor>
					<scroll>$PARAM[focused]</scroll>
					<align>center</align>
				</control>
			</control>
			<!-- Optional rating circle anchored over the top-right of the card. -->
			<control type="group">
				<left>133</left>
				<top>2</top>
				<include condition="Skin.HasSetting(circle_rating) | Skin.HasSetting(circle_userrating)">RatingCircle</include>
			</control>
		</definition>
	</include>
	<!-- Horizontal episode/video card used by InfoWall when content is episodes,
	     generic videos, or music videos in thumb mode.
	     Current styling is: image on top, metadata below, minimal progress line. -->
	<include name="InfoWallEpisodeLayout">
		<param name="main_label">$INFO[ListItem.Title]</param>
		<param name="sub_label">$INFO[ListItem.TVShowTitle]</param>
		<param name="thumb_label">$INFO[ListItem.Season,,x]$INFO[ListItem.Episode]</param>
		<param name="fallback_image">DefaultTVShows.png</param>
		<param name="focused">false</param>
		<definition>
			<!-- Focus highlight card, slightly larger than the base card. -->
			<control type="image">
				<top>8</top>
				<left>13</left>
				<width>294</width>
				<height>167</height>
				<texture colordiffuse="button_focus">colors/white.png</texture>
				<bordertexture border="21" infill="false">overlays/shadow.png</bordertexture>
				<bordersize>20</bordersize>
				<visible>$PARAM[focused]</visible>
				<include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
			</control>
			<!-- Episode/video thumbnail image. -->
			<control type="image">
				<left>15</left>
				<top>10</top>
				<width>290</width>
				<height>163</height>
				<texture fallback="$PARAM[fallback_image]" background="true">$VAR[InfoWallThumbVar]</texture>
				<aspectratio>scale</aspectratio>
				<bordersize>20</bordersize>
			</control>
			<!-- Watched/unwatched badge pinned to the image's top-right corner. -->
			<include content="PosterWatchedBadge">
				<param name="left" value="263" />
				<param name="top" value="29" />
				<param name="size" value="22" />
			</include>
			<!-- Shared under-card metadata block:
			     title on line 1, year/date detail on line 2. -->
			<include content="PosterMetaBlock">
				<param name="left" value="36" />
				<param name="top" value="161" />
				<param name="width" value="266" />
				<param name="title_height" value="24" />
				<param name="detail_top" value="177" />
				<param name="detail_height" value="18" />
				<param name="title_label" value="$PARAM[main_label]" />
				<param name="detail_label" value="$INFO[ListItem.Premiered]" />
				<param name="detail_label_compact" value="$INFO[ListItem.Premiered]" />
				<param name="compact_for_tvshows" value="false" />
			</include>
			<!-- Slim progress indicator for partially watched episodes/videos. -->
			<control type="progress">
				<left>35</left>
				<top>243</top>
				<width>250</width>
				<height>1</height>
				<texturebg></texturebg>
				<midtexture colordiffuse="button_focus" border="3">progress/texturebg_alt_white.png</midtexture>
				<info>ListItem.PercentPlayed</info>
				<visible>!Integer.IsEqual(ListItem.PercentPlayed,0)</visible>
			</control>
			<!-- Optional rating circle overlay. -->
			<control type="group">
				<left>134</left>
				<top>8</top>
				<include condition="Skin.HasSetting(circle_rating) | Skin.HasSetting(circle_userrating)">RatingCircle</include>
			</control>
		</definition>
	</include>
	<!-- Vertical movie/TV poster card used by InfoWall for movies, sets, shows,
	     seasons, and poster-style music videos.
	     This layout changes behavior depending on whether a real poster art image exists. -->
	<include name="InfoWallMovieLayout">
		<param name="focused">false</param>
		<definition>
			<!-- Fallback branch used when no poster art exists and the tile must rely on
			     the generic icon plus a larger centered title. -->
			<control type="group">
				<visible>String.IsEmpty(ListItem.Art(poster))</visible>
				<!-- Focus highlight for the fallback branch. -->
				<control type="image">
					<left>15</left>
					<top>-10</top>
					<width>290</width>
					<height>415</height>
					<texture colordiffuse="button_focus">colors/white.png</texture>
					<bordersize>20</bordersize>
					<visible>$PARAM[focused]</visible>
					<include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
				</control>
				<!-- Large centered fallback title when no poster exists. -->
				<control type="textbox">
					<left>40</left>
					<top>244</top>
					<width>242</width>
					<height>120</height>
					<font>font27</font>
					<align>center</align>
					<aligny>center</aligny>
					<label>$INFO[ListItem.Label]</label>
					<autoscroll time="2000" delay="3000" repeat="5000">$PARAM[focused]</autoscroll>
					<visible>!ListItem.IsParentFolder</visible>
				</control>
				<!-- Generic icon art fallback. -->
				<control type="image">
					<left>24</left>
					<top>-1</top>
					<width>272</width>
					<height>270</height>
					<texture fallback="DefaultMovies.png" background="true">$INFO[ListItem.Icon]</texture>
					<aspectratio>scale</aspectratio>
					<bordersize>20</bordersize>
				</control>
			</control>
			<!-- Main poster-art branch used when ListItem.Art(poster) exists. -->
			<control type="group">
				<visible>!String.IsEmpty(ListItem.Art(poster))</visible>
				<!-- Focus highlight card for poster content. -->
				<control type="image">
					<left>11</left>
					<top>-14</top>
					<width>298</width>
					<height>423</height>
					<texture colordiffuse="button_focus">colors/white.png</texture>
					<bordertexture border="21" infill="false">overlays/shadow.png</bordertexture>
					<bordersize>20</bordersize>
					<visible>$PARAM[focused]</visible>
					<include condition="$PARAM[focused]">Animation_FocusTextureFade</include>
				</control>
				<!-- Actual poster art. -->
				<control type="image">
					<left>15</left>
					<top>-10</top>
					<width>290</width>
					<height>415</height>
					<texture background="true">$INFO[ListItem.Art(poster)]</texture>
					<aspectratio>scale</aspectratio>
					<bordertexture border="21" infill="false">overlays/shadow.png</bordertexture>
					<bordersize>20</bordersize>
				</control>
				<!-- Watched/unwatched badge for poster cards. -->
				<include content="PosterWatchedBadge">
					<param name="left" value="269" />
					<param name="top" value="2" />
					<param name="size" value="28" />
				</include>
			</control>
			<!-- Optional rating circle floating over the poster card. -->
			<control type="group">
				<left>135</left>
				<top>-8</top>
				<include condition="Skin.HasSetting(circle_rating) | Skin.HasSetting(circle_userrating)">RatingCircle</include>
			</control>
			<!-- Minimal played-progress line at the bottom of the poster card. -->
			<control type="progress">
				<left>35</left>
				<top>365</top>
				<width>250</width>
				<height>1</height>
				<texturebg></texturebg>
				<midtexture colordiffuse="button_focus" border="3">progress/texturebg_alt_white.png</midtexture>
				<info>ListItem.PercentPlayed</info>
				<visible>!Integer.IsEqual(ListItem.PercentPlayed,0)</visible>
			</control>
		</definition>
	</include>
	<!-- View registration for Kodi view id 54.
	     This switches between the poster, episode, music, and picture layouts above
	     depending on the active container content type. -->
	<include name="View_54_InfoWall">
		<control type="group">
			<!-- View open/close and visibility behavior for the whole InfoWall region. -->
			<include>OpenClose_Right</include>
			<left>100</left>
			<top>0</top>
			<visible>Control.IsVisible(54)</visible>
			<include>Visible_Right</include>
			<control type="panel" id="54">
				<!-- Main panel geometry and directional navigation for the InfoWall view. -->
				<left>490</left>
				<top>0</top>
				<right>15</right>
				<height>100%</height>
				<onleft>9000</onleft>
				<onright>531</onright>
				<onup condition="Integer.IsGreater(Container.NumPages,1)">54</onup>
				<onup condition="!Integer.IsGreater(Container.NumPages,1)">9000</onup>
				<ondown>54</ondown>
				<viewtype label="31101">icon</viewtype>
				<preloaditems>2</preloaditems>
				<pagecontrol>531</pagecontrol>
				<scrolltime tween="cubic" easing="out">500</scrolltime>
				<visible>Container.Content(artists) | Container.Content(albums) | Container.Content(sets) | Container.Content(movies) | Container.Content(tvshows) | Container.Content(seasons) | Container.Content(episodes) | Container.Content(musicvideos) | Container.Content(images) | Container.Content(videos) | Container.Content(games) | $EXP[videoasset_true]</visible>
				<!-- Poster-style cards for movies, sets, shows, seasons, and poster music videos. -->
				<itemlayout height="445" width="320" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | $EXP[videoasset_true] | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<left>30</left>
						<top>120</top>
						<include>InfoWallMovieLayout</include>
					</control>
				</itemlayout>
				<!-- Focused poster-style cards. -->
				<focusedlayout height="445" width="320" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | $EXP[videoasset_true] | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>30</left>
						<top>120</top>
						<include content="InfoWallMovieLayout">
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
				<!-- Horizontal episode/video cards. -->
				<itemlayout height="301" width="320" condition="Container.Content(episodes) | Container.Content(videos) | [Container.Content(musicvideos) + !Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<left>30</left>
						<top>110</top>
						<include content="InfoWallEpisodeLayout">
							<param name="focused" value="false" />
							<param name="thumb_label" value="$INFO[ListItem.Label2]" />
						</include>
					</control>
				</itemlayout>
				<!-- Focused horizontal episode/video cards. -->
				<focusedlayout height="301" width="320" condition="Container.Content(episodes) | Container.Content(videos) | [Container.Content(musicvideos) + !Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>30</left>
						<top>110</top>
						<include content="InfoWallEpisodeLayout">
							<param name="focused" value="true" />
							<param name="thumb_label" value="$INFO[ListItem.Label2]" />
						</include>
					</control>
				</focusedlayout>
				<!-- Square artwork cards for artists and albums. -->
				<itemlayout height="410" width="310" condition="Container.Content(artists) | Container.Content(albums)">
					<control type="group">
						<top>150</top>
						<left>40</left>
						<include>InfoWallMusicLayout</include>
					</control>
				</itemlayout>
				<!-- Focused square artwork cards. -->
				<focusedlayout height="410" width="310" condition="Container.Content(artists) | Container.Content(albums)">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<top>150</top>
						<left>40</left>
						<include content="InfoWallMusicLayout">
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
				<!-- Picture cards used for image libraries. -->
				<itemlayout height="401" width="378" condition="Container.Content(images)">
					<control type="group">
						<left>0</left>
						<top>150</top>
						<include>InfoWallPictureLayout</include>
					</control>
				</itemlayout>
				<!-- Focused picture cards. -->
				<focusedlayout height="401" width="378" condition="Container.Content(images)">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>0</left>
						<top>150</top>
						<include content="InfoWallPictureLayout">
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
			</control>
		</control>
	</include>
</includes>
