<?xml version="1.0" encoding="UTF-8"?>
<!-- Purpose: Sukha's custom Wall view implementation. -->
<!-- Usage: Provides the wall/grid layouts used by the video library when the wall view is active. -->
<includes>
	<!-- Reusable include: View_500_Wall. -->
	<include name="View_500_Wall">
		<control type="group">
			<include>OpenClose_Right</include>
			<left>20</left>
			<top>0</top>
			<visible>Control.IsVisible(500)</visible>
			<include>Visible_Right</include>
				<control type="panel" id="500">
					<left>0</left>
					<top>0</top>
					<width>2020</width>
					<height>100%</height>
					<showparentdiritems>false</showparentdiritems>
				<onleft>9000</onleft>
				<onright>531</onright>
				<onup condition="Integer.IsGreater(Container.NumPages,1)">500</onup>
				<onup condition="!Integer.IsGreater(Container.NumPages,1)">9000</onup>
				<ondown>500</ondown>
				<viewtype label="31102">icon</viewtype>
				<preloaditems>2</preloaditems>
				<pagecontrol>531</pagecontrol>
				<scrolltime tween="cubic" easing="out">500</scrolltime>
				<itemlayout height="326" width="202" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<top>18</top>
						<control type="image">
							<left>4</left>
							<top>0</top>
							<width>176</width>
							<height>258</height>
							<texture fallback="DefaultMovies.png" background="true">$VAR[PosterThumbVar]</texture>
							<aspectratio>scale</aspectratio>
						</control>
						<control type="image">
							<left>156</left>
							<top>0</top>
							<width>24</width>
							<height>24</height>
							<aspectratio>keep</aspectratio>
							<texture colordiffuse="selected">overlays/badge.png</texture>
							<visible>!Integer.IsGreater(ListItem.Playcount,0) + !String.IsEqual(ListItem.Overlay,OverlayWatched.png) + !ListItem.IsParentFolder</visible>
						</control>
						<include content="PosterMetaBlock" />
					</control>
				</itemlayout>
				<focusedlayout height="326" width="202" condition="Container.Content(movies) | Container.Content(sets) | Container.Content(tvshows) | Container.Content(seasons) | [Container.Content(musicvideos) + Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<top>18</top>
						<control type="image">
							<left>2</left>
							<top>-2</top>
							<width>180</width>
							<height>262</height>
							<texture colordiffuse="button_focus">colors/white.png</texture>
							<visible>Control.HasFocus(500)</visible>
							<include>Animation_FocusTextureFade</include>
						</control>
						<control type="image">
							<left>4</left>
							<top>0</top>
							<width>176</width>
							<height>258</height>
							<texture fallback="DefaultMovies.png" background="true">$VAR[PosterThumbVar]</texture>
							<aspectratio>scale</aspectratio>
						</control>
						<control type="image">
							<left>156</left>
							<top>0</top>
							<width>24</width>
							<height>24</height>
							<aspectratio>keep</aspectratio>
							<texture colordiffuse="selected">overlays/badge.png</texture>
							<visible>!Integer.IsGreater(ListItem.Playcount,0) + !String.IsEqual(ListItem.Overlay,OverlayWatched.png) + !ListItem.IsParentFolder</visible>
						</control>
						<include content="PosterMetaBlock" />
					</control>
				</focusedlayout>
				<itemlayout height="301" width="300" condition="Container.Content(episodes) | Container.Content(videos) | [Container.Content(musicvideos) + !Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<top>110</top>
						<include content="InfoWallEpisodeLayout">
							<param name="label" value="$INFO[ListItem.Label]" />
							<param name="thumb_label" value="$INFO[ListItem.Label2]" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout height="301" width="300" condition="Container.Content(episodes) | Container.Content(videos) | [Container.Content(musicvideos) + !Skin.HasSetting(show_musicvideoposter)]">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<top>110</top>
						<include content="InfoWallEpisodeLayout">
							<param name="focused" value="true" />
							<param name="thumb_label" value="$INFO[ListItem.Label2]" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="425" width="442" condition="Container.Content(images)">
					<control type="group">
						<left>40</left>
						<top>150</top>
						<include>InfoWallPictureLayout</include>
					</control>
				</itemlayout>
				<focusedlayout height="425" width="442" condition="Container.Content(images)">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<left>40</left>
						<top>150</top>
						<include content="InfoWallPictureLayout">
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="401" width="300" condition="Container.Content(artists) | Container.Content(albums)">
					<control type="group">
						<top>150</top>
						<include content="InfoWallMusicLayout">
							<param name="fallback_image" value="DefaultMusicSongs.png" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout height="401" width="300" condition="Container.Content(artists) | Container.Content(albums)">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<top>150</top>
						<include content="InfoWallMusicLayout">
							<param name="fallback_image" value="DefaultMusicSongs.png" />
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="401" width="300" condition="Container.Content(addons)">
					<control type="group">
						<top>150</top>
						<include content="InfoWallMusicLayout">
							<param name="fallback_image" value="DefaultAddon.png" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout height="401" width="300" condition="Container.Content(addons)">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<top>150</top>
						<include content="InfoWallMusicLayout">
							<param name="fallback_image" value="DefaultAddon.png" />
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="401" width="300" condition="Container.Content(favourites)">
					<control type="group">
						<top>150</top>
						<include content="InfoWallMusicLayout">
							<param name="fallback_image" value="DefaultFavourites.png" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout height="401" width="300" condition="Container.Content(favourites)">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<top>150</top>
						<include content="InfoWallMusicLayout">
							<param name="fallback_image" value="DefaultFavourites.png" />
							<param name="focused" value="true" />
						</include>
					</control>
				</focusedlayout>
				<itemlayout height="301" width="300">
					<control type="group">
						<top>110</top>
						<include content="InfoWallEpisodeLayout">
							<param name="label" value="$INFO[ListItem.Label]" />
							<param name="thumb_label" value="$INFO[ListItem.Label2]" />
						</include>
					</control>
				</itemlayout>
				<focusedlayout height="301" width="300">
					<control type="group">
						<depth>DepthContentPopout</depth>
						<top>110</top>
						<include content="InfoWallEpisodeLayout">
							<param name="focused" value="true" />
							<param name="label" value="$INFO[ListItem.Label]" />
							<param name="thumb_label" value="$INFO[ListItem.Label2]" />
						</include>
					</control>
				</focusedlayout>
			</control>
		</control>
	</include>
</includes>
